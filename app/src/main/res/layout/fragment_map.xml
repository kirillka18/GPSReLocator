<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- OSMDroid MapView (full screen) -->
    <org.osmdroid.views.MapView
        android:id="@+id/map_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Center crosshair — pinned to exact screen center to match OSMDroid mapCenter -->
    <ImageView
        android:id="@+id/iv_crosshair"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_crosshair"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:ignore="ContentDescription" />

    <!-- Status badge top left -->
    <LinearLayout
        android:id="@+id/status_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:background="@drawable/bg_status_inactive"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <View
            android:id="@+id/status_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_status_dot"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_inactive"
            android:textColor="@color/colorOnSurfaceSecondary"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- My location FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_my_location"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:contentDescription="My location"
        android:src="@drawable/ic_my_location"
        app:backgroundTint="@color/colorSurface"
        app:tint="@color/colorOnSurface"
        app:fabSize="mini"
        app:elevation="6dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottom_panel" />

    <!-- Bottom Control Panel -->
    <LinearLayout
        android:id="@+id/bottom_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_bottom_sheet"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Drag handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:background="#3DFFFFFF" />

        <!-- Coordinates row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_place"
                app:tint="@color/colorPrimary"
                android:layout_marginEnd="8dp"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/tv_coordinates"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/tap_map_hint"
                android:textColor="@color/colorOnSurfaceSecondary"
                android:textSize="13sp"
                android:singleLine="true"
                android:ellipsize="end" />

            <!-- Save / Star button -->
            <ImageButton
                android:id="@+id/btn_save_place"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_star_outline"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/btn_save_place"
                android:padding="6dp" />
        </LinearLayout>

        <!-- Relocate button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_relocate"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/btn_relocate"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/colorOnPrimary"
            app:backgroundTint="@color/colorPrimary"
            app:cornerRadius="12dp"
            android:layout_marginBottom="8dp" />

        <!-- Cancel button (shown only when mocking is active) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel_relocation"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/btn_cancel_relocation"
            android:textSize="16sp"
            android:textColor="@color/colorError"
            app:backgroundTint="@color/colorSurface3"
            app:strokeColor="@color/colorError"
            app:strokeWidth="1dp"
            app:cornerRadius="12dp"
            android:visibility="gone" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
