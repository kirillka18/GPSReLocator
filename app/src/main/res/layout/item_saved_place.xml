<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/colorSurface"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/colorDivider"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Yellow location icon -->
        <ImageView
            android:id="@+id/iv_place_icon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_location_pin"
            android:background="@drawable/bg_status_active"
            android:padding="10dp"
            android:contentDescription=""
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Place name -->
        <TextView
            android:id="@+id/tv_place_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/colorOnSurface"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp"
            android:singleLine="true"
            android:ellipsize="end"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/iv_place_icon"
            app:layout_constraintEnd_toStartOf="@id/btn_go_here" />

        <!-- Coordinates -->
        <TextView
            android:id="@+id/tv_place_coords"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/colorOnSurfaceSecondary"
            android:textSize="12sp"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp"
            android:singleLine="true"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/tv_place_name"
            app:layout_constraintStart_toEndOf="@id/iv_place_icon"
            app:layout_constraintEnd_toStartOf="@id/btn_go_here" />

        <!-- Go here button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_go_here"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/btn_go_here"
            android:textSize="13sp"
            android:textColor="@color/colorOnPrimary"
            app:backgroundTint="@color/colorPrimary"
            app:cornerRadius="8dp"
            android:layout_marginStart="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_delete" />

        <!-- Delete button -->
        <ImageButton
            android:id="@+id/btn_delete"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_delete"
            app:tint="@color/colorError"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/delete"
            android:padding="6dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
