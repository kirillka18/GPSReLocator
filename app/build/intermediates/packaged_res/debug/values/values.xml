    <style name="AlertDialog.GPSReLocator.Body" parent="MaterialAlertDialog.MaterialComponents.Body.Text">
        <item name="android:textColor">@color/colorOnSurfaceSecondary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>
    <style name="AlertDialog.GPSReLocator.Button.Negative" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/colorOnSurfaceSecondary</item>
    </style>
    <style name="AlertDialog.GPSReLocator.Button.Positive" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="AlertDialog.GPSReLocator.Title" parent="MaterialAlertDialog.MaterialComponents.Title.Text.CenterStacked">
        <item name="android:textColor">@color/colorOnSurface</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="ShapeAppearance.GPSReLocator.Dialog" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
    <style name="TextAppearance.GPSReLocator.SectionHeader" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="TextAppearance.GPSReLocator.Subtitle" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/colorOnSurfaceSecondary</item>
    </style>
